---
import MainLayout from "../Layouts/MainLayout.astro"
import NavBar from "../Components/NavBar.astro";
const active = Astro.url.pathname;
---
<MainLayout>
	<NavBar active={active} />

	<main class="max-w-4xl mx-auto p-8 flex-1">
    <h1 class="text-3xl font-bold mb-4 text-gray-200">Contacto</h1>
    <p class="text-gray-200">Formulario o correo de contacto.</p>
	</main>
</MainLayout>
