---
import Logo from './Logo.astro';
// Accept `navLinks` as a prop; provide sensible default links
const { navLinks } = Astro.props;
---

<!-- Navbar Flotante con efecto de cristal -->
<nav class="fixed top-0 w-full z-50 px-4 md:px-6 py-2">
  <div
    class="max-w-7xl mx-auto glass-card rounded-2xl px-6 md:px-8 py-3 flex justify-between items-center border-white/5 shadow-2xl shadow-blue-900/10"
  >
    <!-- Identidad / Logo -->
    <a href="/" class="flex items-center gap-3 group cursor-pointer">
      <Logo size="40" class="group-hover:scale-105 transition-transform" title="DevJorge" />
      <div class="flex flex-col">
        <span class="font-bold tracking-tight text-sm leading-none text-white"
          >Jorge Borges</span
        >
        <span
          class="text-[9px] text-white/40 uppercase tracking-[2px] mt-1 font-semibold"
          >Software Architect</span
        >
      </div>
    </a>

    <!-- Navegación para Escritorio -->
    <div
      class="hidden md:flex gap-8 text-[13px] font-semibold text-white/50 uppercase tracking-wider"
    >
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="hover:text-white transition-colors relative group"
          >
            {link.name}
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-blue-500 transition-all group-hover:w-full" />
          </a>
        ))
      }
    </div>

    <!-- Botón de Acción -->
    <a
      href="/contacto"
      target="_blank"
      class="bg-blue-600 hover:bg-blue-500 text-white px-5 py-2.5 rounded-xl text-xs font-bold transition-all shadow-lg shadow-blue-500/20 flex items-center gap-2 active:scale-95"
    >
      CONTACTAR
      <span class="material-symbols-rounded text-sm">send</span>
    </a>
  </div>
</nav>

<style>
  /* Navbar entry animation */
  nav {
    animation: nav-entry 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes nav-entry {
    from {
      transform: translateY(-100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .glass-card {
    background: rgba(22, 27, 34, 0.7);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .glass-card:hover {
    border-color: #3B82F6;
    box-shadow: 0 0 40px rgba(59, 130, 246, 0.15);
    transform: translateY(-8px);
}
</style>
