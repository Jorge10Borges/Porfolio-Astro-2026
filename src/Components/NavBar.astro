            </div>
            <div>
              <div>
                <span class="font-bold text-lg">JORGE<span class="font-light">BORGES</span></span>
              </div>
              <div class="text-sm">Desarrollador de Software</div>
            </div>
            
          </a>
      </div>

      <!-- secondary nav -->
      <div class="hidden md:flex items-center space-x-1">
        <div class="relative h-full flex items-center">
          <a href="/" class={active === '/' ? 'py-5 px-3 activo' : 'py-5 px-3 text-white/70 hover:text-white'}>Inicio</a>
          <div class="left-0 bottom-4 absolute bar"></div>
        </div>
        <div class="relative h-full flex items-center">
          <a href="/sobre-mi" class={active === '/sobre-mi' ? 'py-5 px-3 activo' : 'py-5 px-3 text-white/70 hover:text-white'}>Sobre Mi</a>
          <div class="left-0 bottom-4 absolute bar"></div>
        </div>
        <div class="relative h-full flex items-center">
          <a href="/proyectos" class={active === '/proyectos' ? 'py-5 px-3 activo' : 'py-5 px-3 text-white/70 hover:text-white'}>Proyectos</a>
          <div class="left-0 bottom-4 absolute bar"></div>
        </div>
        <div class="relative h-full flex items-center">
          <a href="/contacto" class={active === '/contacto' ? 'py-5 px-3 activo' : 'py-5 px-3 text-white/70 hover:text-white'}>Contacto</a>
          <div class="left-0 bottom-4 absolute bar"></div>
        </div>
      </div>

      <!-- mobile button goes here -->
      <div class="md:hidden flex items-center">
        <button class="mobile-menu-button">
          <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- mobile menu -->
  <div class="mobile-menu hidden md:hidden">
    <a href="#" class="block py-2 px-4 text-sm hover:bg-gray-200">Features</a>
    <a href="#" class="block py-2 px-4 text-sm hover:bg-gray-200">Pricing</a>
  </div>
</nav>

<style>
  /* Barra centrada que crece desde el medio hacia afuera */
  .bar {
    position: absolute;
    left: 50%;
    bottom: 1rem; /* coincide con bottom-4 */
    width: 60%;
    height: 2px;
    background: white;
    transform: translateX(-50%) scaleX(0);
    transform-origin: center;
    transition: transform 0.45s cubic-bezier(.2,.8,.2,1);
  }

  /* Al pasar el ratón o al enfocarse, crecer desde el centro */
  .relative:hover .bar,
  .relative:focus-within .bar {
    transform: translateX(-50%) scaleX(1);
    
  }

  /* Clase reutilizable para el link activo del nav */
  .activo {
    color: white;
  }
</style>

<script>
  // grab everything we need
  const btn = document.querySelector("button.mobile-menu-button");
  const menu = document.querySelector(".mobile-menu");

  // add event listeners
  btn.addEventListener("click", () => {
    menu.classList.toggle("hidden");
  });
</script>

