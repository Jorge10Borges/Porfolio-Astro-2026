---
import Logo from "./Logo.astro";

interface Props {
  navLinks?: Array<{ name: string; href: string }>;
}

const { navLinks = [] } = Astro.props;

// Enlaces por defecto si no se proporcionan props
const defaultLinks = [
  { name: "Inicio", href: "/" },
  { name: "Proyectos", href: "#proyectos" },
  { name: "Trayectoria", href: "#sobre-mi" },
];

const linksToDisplay = navLinks.length > 0 ? navLinks : defaultLinks;
---

<!-- Footer adaptado al diseño provisto por el usuario -->
<footer class="relative pt-32 pb-12 px-6 border-t border-white/5 bg-[#080B14] overflow-hidden">
  <!-- Elementos Decorativos de Fondo -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-linear-to-r from-transparent via-blue-500/40 to-transparent"></div>
  <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-blue-600/5 blur-[120px] rounded-full"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <!-- Grid Principal del Footer -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-16 mb-24">
      
      <!-- Bloque 1: El Arquitecto (5 columnas) -->
      <div class="md:col-span-5 space-y-8 text-left">
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 flex items-center justify-center rounded-lg">
              <a href="/" class="block">
                <Logo size="54" class="rounded-2xl shadow-lg shadow-blue-500/20 group-hover:scale-105 transition-transform p-2" title="DevJorge" />
              </a>
            </div>
            <div>
              <h3 class="font-bold text-2xl tracking-tighter text-white leading-none">Jorge Borges</h3>
              <p class="text-[10px] text-blue-400 font-bold uppercase tracking-[3px] mt-1">Software Architect & Business Strategist</p>
            </div>
          </div>
          <p class="text-white/50 text-base leading-relaxed max-w-md">
            Fusionando la precisión del código con la visión administrativa. 25 años transformando infraestructuras críticas y liderando la evolución digital en Latinoamérica.
          </p>
        </div>

        <!-- Badges de Alcance Regional -->
        <div class="flex flex-wrap gap-3">
          <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-[10px] font-bold text-white/40 uppercase tracking-widest">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
            Argentina
          </div>
          <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-[10px] font-bold text-white/40 uppercase tracking-widest">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
            Venezuela
          </div>
          <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-[10px] font-bold text-white/40 uppercase tracking-widest">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
            Remote Global
          </div>
        </div>
      </div>

      <!-- Bloque 2: Conocimiento y Navegación (4 columnas) -->
      <div class="md:col-span-4 grid grid-cols-2 gap-8 text-left">
        <div class="space-y-6">
          <h4 class="text-[11px] font-black uppercase tracking-[4px] text-blue-500">Expertise</h4>
          <ul class="space-y-4">
            <li><a href="#proyectos" class="text-white/40 hover:text-white transition-colors text-sm">Arquitectura Cloud</a></li>
            <li><a href="#proyectos" class="text-white/40 hover:text-white transition-colors text-sm">Modernización VB6</a></li>
            <li><a href="#proyectos" class="text-white/40 hover:text-white transition-colors text-sm">Sistemas ERP/POS</a></li>
            <li><a href="#proyectos" class="text-white/40 hover:text-white transition-colors text-sm">E-commerce High-End</a></li>
          </ul>
        </div>
        <div class="space-y-6">
          <h4 class="text-[11px] font-black uppercase tracking-[4px] text-blue-500">Navegación</h4>
          <nav class="flex flex-col gap-4">
            {linksToDisplay.map((link) => (
              <a href={link.href} class="text-white/40 hover:text-blue-400 transition-all text-sm">
                {link.name}
              </a>
            ))}
          </nav>
        </div>
      </div>

      <!-- Bloque 3: Acción Inmediata -->
      <div class="md:col-span-3 space-y-6 text-left">
        <h4 class="text-[11px] font-black uppercase tracking-[4px] text-blue-500">Disponibilidad</h4>
        <div class="p-6 rounded-3xl border border-blue-500/20 bg-blue-500/5 space-y-4 backdrop-blur-sm">
          <div class="flex items-center gap-3">
            <div class="relative">
              <div class="w-3 h-3 bg-emerald-500 rounded-full"></div>
              <div class="absolute inset-0 w-3 h-3 bg-emerald-500 rounded-full animate-ping"></div>
            </div>
            <span class="text-xs font-bold text-white uppercase tracking-widest">Consultoría Activa</span>
          </div>
          <p class="text-[11px] text-white/40 leading-relaxed">
            Aceptando desafíos de modernización y auditoría técnica de alto impacto a nivel global.
          </p>
          <a href="https://wa.me/584246334377" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 w-full py-3 bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-bold rounded-xl transition-all shadow-lg shadow-blue-500/20 uppercase tracking-widest">
            Contactar Ahora
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Barra Inferior -->
    <div class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8 text-left">
      <div class="flex flex-col md:flex-row items-center gap-6">
        <div>
          <p class="text-[10px] text-white/20 font-bold uppercase tracking-[4px]">
            © 2026 Jorge Borges — Cum Laude Software Architect
          </p>
          <p class="text-[9px] text-white/10 uppercase tracking-[2px] mt-1 hidden md:block">
            Especialista en Transformación de Legados & Estrategia Digital
          </p>
        </div>
        <div class="hidden md:block h-8 w-px bg-white/10"></div>
        <div class="flex items-center gap-6">
          <a href="https://github.com/Jorge10Borges" target="_blank" rel="noopener noreferrer" class="text-white/20 hover:text-white transition-colors">
             <span class="text-[10px] font-bold uppercase tracking-widest">GitHub</span>
          </a>
          <a href="#" target="_blank" rel="noopener noreferrer" class="text-white/20 hover:text-white transition-colors">
             <span class="text-[10px] font-bold uppercase tracking-widest">LinkedIn</span>
          </a>
        </div>
      </div>
      
      <div class="flex items-center gap-3 px-4 py-2 rounded-full bg-white/5 border border-white/5">
        <span class="text-[10px] text-white/30 font-bold uppercase tracking-widest flex items-center gap-2">
          Potenciado por 
          <span class="text-blue-500">✦</span> 
          Astro Nativo & Tailwind
        </span>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Optimizaciones de tipografía y efectos específicos de Astro */
  footer {
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>
